# CodeType — Environment Variables
# Copy this file to .env and fill in your values.
# The Grok API key can also be set through the Settings page in the UI.

# xAI Grok API key for AI question generation
# Get yours at: https://console.x.ai
VITE_GROK_API_KEY=xai-your-key-here

# Google OAuth Client ID for sign-in
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

